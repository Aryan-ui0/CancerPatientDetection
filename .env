# ─── Server ───────────────────────────────────────────
PORT=5000

# ─── MongoDB ──────────────────────────────────────────
# Local MongoDB (default):
MONGO_URI=mongodb://localhost:27017/oncoclear

# MongoDB Atlas (cloud) — uncomment and paste your connection string:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/oncoclear?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET=oncoclear_super_secret_jwt_key_change_me_in_production_abc123xyz

# ─── CORS ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
